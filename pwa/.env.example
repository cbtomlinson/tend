# Copy to .env (gitignored) and fill in. Server-side only — these are read by the
# Vite dev proxy in Node and NEVER exposed to the browser (no VITE_ prefix).

# Anthropic API key for the capture vision/OCR step.
ANTHROPIC_API_KEY=

# Optional: which vision model reads the photos.
# Default (unset) = claude-opus-4-8 (best at handwriting).
# To save a little per scan, set: VISION_MODEL=claude-sonnet-4-6
VISION_MODEL=

# --- Email (Resend) — server-side only ---
RESEND_API_KEY=
# Where the board is emailed. With the default sender below, Resend only allows
# sending to YOUR Resend account email until you verify a domain.
EMAIL_TO=
# Sender. Default works for sending to your own account email; a verified domain
# is needed to send elsewhere (e.g. to Kindle).
EMAIL_FROM=Tend <onboarding@resend.dev>
# Optional Send-to-Kindle address (e.g. you_xxxx@kindle.com). Needs a verified
# Resend domain whose address you've added to Amazon's approved sender list.
KINDLE_TO=
